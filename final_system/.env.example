# =============================================================================
# WhatsBot SaaS — plantilla (copiar a .env y rellenar)
# Migrado desde bot legacy en raíz — ver docs/INCREMENTAL_GUIDE.md Fase 1
# =============================================================================

# --- API pública (webhook Twilio + app Flutter) ---
API_PUBLIC_URL=https://tu-dominio-o-ngrok.ngrok-free.app
CORS_ORIGINS=*

# --- Servidor ---
HOST=0.0.0.0
PORT=5000
DEBUG=false

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+573001234567
TWILIO_REST_WEBHOOK_REPLIES=0

# --- Admin legacy (confirmación por WhatsApp personal del dueño) ---
ADMIN_WHATSAPP_NUMBER=whatsapp:+573001234567
ADMIN_REMINDER_INTERVAL_SECONDS=300
ADMIN_REMINDER_MAX_SECONDS=3600

# --- Base de datos (fuente de verdad SaaS) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsbot

# --- Redis (opcional, multi-instancia) ---
REDIS_URL=redis://localhost:6379

# --- JWT (app Flutter WhatsBot) ---
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=1440

# --- Negocio default (semilla; luego en BD por business_id) ---
DEFAULT_BUSINESS_NAME=Mi Negocio

# --- Google Sheets (opcional, espejo) ---
GOOGLE_SHEETS_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=credentials/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_ID_MENU=
GOOGLE_SHEET_ID_ORDERS=

# --- Caché Sheets (segundos) ---
MENU_CACHE_TTL_SECONDS=60
ORDERS_CACHE_TTL_SECONDS=30
BLOCKED_USERS_CACHE_TTL_SECONDS=15
SHEETS_INCREMENTAL_THRESHOLD=500
SHEETS_FULL_REFRESH_INTERVAL_SECONDS=3600
SHEETS_INCREMENTAL_BATCH_SIZE=100

# --- Bot runtime (hasta Fase 2+ gateway) ---
STATE_PERSIST_PATH=data/user_states.json
PARSER_ERROR_LOG_PATH=data/parser_errors.jsonl
FLOWS_PATH=../flows/restaurant_flow.json

# --- Legacy Flask (compatibilidad transitoria) ---
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=

# --- Scripts de despliegue ---
DEPLOY_URL=
DEPLOY_TIMEOUT=60
