FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Admin (recibe pedidos y confirma con CONFIRMAR ORD-XXXXXXXX)
ADMIN_WHATSAPP_NUMBER=whatsapp:+573001234567

# Parser audit log (JSONL)
PARSER_ERROR_LOG_PATH=data/parser_errors.jsonl

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_PATH=credentials/google-service-account.json
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id
# Cloud hosting (Render/Railway): paste full service-account JSON on one line
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Caché y sincronización con Google Sheets (tiempos en segundos)

# Cómo envía respuestas el bot: 0 = TwiML en el webhook (sandbox); 1 = Twilio REST API (producción)
TWILIO_REST_WEBHOOK_REPLIES=0

# Cada cuántos segundos refresca menú y usuarios desde Google Sheets (sin consultar por mensaje)
MENU_CACHE_TTL_SECONDS=60

# Cada cuántos segundos refresca pedidos y reservas desde Google Sheets
ORDERS_CACHE_TTL_SECONDS=30

# Cada cuántos segundos refresca la lista de usuarios bloqueados (blockon/blockoff)
BLOCKED_USERS_CACHE_TTL_SECONDS=15

# A partir de cuántas filas en Sheets usa refresh incremental en lugar de leer todo
SHEETS_INCREMENTAL_THRESHOLD=500

# Cada cuántos segundos fuerza un refresh completo de Sheets (aunque haya muchas filas)
SHEETS_FULL_REFRESH_INTERVAL_SECONDS=3600

# Cuántas filas nuevas trae en cada refresh incremental de Sheets
SHEETS_INCREMENTAL_BATCH_SIZE=100

# Optional: persist user state to disk (recommended for dev)
STATE_PERSIST_PATH=data/user_states.json

# Restaurant branding
RESTAURANT_NAME=La Casa del Sabor

# Server (waitress via run.py)
HOST=0.0.0.0
PORT=5000
